{
  "name": "mkdocs-modern-theme",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "css:build": "npx @tailwindcss/cli -i mkdocs_modern_theme/css/input.css -o mkdocs_modern_theme/css/theme.css --minify",
    "css:watch": "npx @tailwindcss/cli -i mkdocs_modern_theme/css/input.css -o mkdocs_modern_theme/css/theme.css --watch",
    "copy:mermaid": "cp node_modules/mermaid/dist/mermaid.min.js mkdocs_modern_theme/js/mermaid.min.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "format": "uv run mdformat docs/ tests/docs/ README.md CHANGELOG.md CLAUDE.md && uv run ruff format && uv run djlint --reformat mkdocs_modern_theme/ --extension=html",
    "format:check": "uv run mdformat --check docs/ tests/docs/ README.md CHANGELOG.md CLAUDE.md && uv run ruff format --check && uv run djlint --check mkdocs_modern_theme/ --extension=html",
    "lint": "uv run ruff check && uv run ty check",
    "lint:fix": "uv run ruff check --fix"
  },
  "lint-staged": {
    "*.md": "uv run mdformat",
    "*.py": [
      "uv run ruff format",
      "uv run ruff check --fix"
    ],
    "*.html": "uv run djlint --reformat"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/cli": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "mermaid": "11",
    "tailwindcss": "^4.0.0"
  },
  "packageManager": "pnpm@9.15.3+sha512.1f79bc245a66eb0b07c5d4d83131240774642caaa86ef7d0434ab47c0d16f66b04e21e0c086eb61e62c77efc4d7f7ec071afad3796af64892fae66509173893a"
}
